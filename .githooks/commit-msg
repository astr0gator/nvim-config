#!/bin/sh

# Enforce conventional commit message format:
# feat: add new feature
# fix: bug fix
# docs: documentation changes
# style: formatting, code style
# refactor: refactoring production code
# test: adding tests
# chore: build tasks, config, etc

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Skip empty commits or merge commits
first_line=$(echo "$commit_msg" | head -n 1)
if [ -z "$first_line" ] || echo "$first_line" | grep -qE "^(Merge|Revert|fixup|squash)"; then
    exit 0
fi

# Check for conventional commit format: type(scope): description
# Type is required, scope is optional
allowed_types="feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert"

if ! echo "$first_line" | grep -qE "^($allowed_types)(\(.+\))?: .{1,}$"; then
    echo "✗ Commit message must follow conventional commit format:"
    echo "  type(scope): description"
    echo ""
    echo "Allowed types:"
    echo "  feat     - new feature"
    echo "  fix      - bug fix"
    echo "  docs     - documentation changes"
    echo "  style    - formatting, code style"
    echo "  refactor - refactoring"
    echo "  test     - adding tests"
    echo "  chore    - build, config, maintenance"
    echo "  perf     - performance improvements"
    echo "  ci       - CI/CD changes"
    echo "  build    - build system changes"
    echo ""
    echo "Examples:"
    echo "  feat: add nvim-autopairs plugin"
    echo "  fix(ui): resolve lualine color issue"
    echo "  docs: update README with new conventions"
    echo ""
    echo "Your message: $first_line"
    exit 1
fi

# Check that description doesn't end with a period
if echo "$first_line" | grep -qE "\.$"; then
    echo "✗ Commit message description should not end with a period"
    echo "Your message: $first_line"
    exit 1
fi

exit 0
